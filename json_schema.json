{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClientIntelligenceReport",
  "type": "object",
  "properties": {
    "client_summary": {
      "type": "object",
      "properties": {
        "weekly_overview": { "type": "string" },
        "engagement_level": {
          "type": "string",
          "enum": ["High", "Medium", "Low"]
        }
      },
      "required": ["weekly_overview", "engagement_level"]
    },
    "metrics": {
      "type": "object",
      "properties": {
        "nutrition_adherence": { "$ref": "#/definitions/Insight" },
        "exercise_steps": { "$ref": "#/definitions/Insight" },
        "sleep": { "$ref": "#/definitions/Insight" },
        "water_intake": { "$ref": "#/definitions/Insight" }
      },
      "required": ["nutrition_adherence", "exercise_steps", "sleep", "water_intake"]
    },
    "health_status": {
      "type": "object",
      "properties": {
        "symptoms_stress": { "$ref": "#/definitions/Insight" }
      },
      "required": ["symptoms_stress"]
    },
    "coaching_insights": {
      "type": "object",
      "properties": {
        "key_barriers": {
          "type": "array",
          "items": { "$ref": "#/definitions/Insight" }
        },
        "pending_actions": {
          "type": "array",
          "items": { "$ref": "#/definitions/Insight" }
        },
        "risk_attention_flags": {
          "type": "array",
          "items": { "$ref": "#/definitions/Insight" }
        },
        "recommended_next_action": { "$ref": "#/definitions/Insight" }
      },
      "required": ["key_barriers", "pending_actions", "risk_attention_flags", "recommended_next_action"]
    }
  },
  "required": ["client_summary", "metrics", "health_status", "coaching_insights"],
  "definitions": {
    "Insight": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "description": "A short summary or status value (e.g. 'Poor', '4 Litres', etc.)" },
        "details": { "type": "string", "description": "Detailed explanation." },
        "evidence": { "type": "string", "description": "Exact quote from the transcript supporting this insight." },
        "source_type": {
          "type": "string",
          "enum": ["confirmed_fact", "client_reported", "ai_inference", "missing_info"]
        }
      },
      "required": ["status", "details", "evidence", "source_type"]
    }
  }
}
